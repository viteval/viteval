{
  "name": "@viteval/cli",
  "version": "1.0.0-rc.0",
  "description": "Command line interface for Viteval - Next generation LLM evaluation framework powered by Vitest.",
  "homepage": "https://github.com/viteval/viteval#readme",
  "bugs": "https://github.com/viteval/viteval/issues",
  "repository": "viteval/viteval",
  "bin": {
    "viteval": "cli.mjs"
  },
  "type": "module",
  "main": "cli.mjs",
  "scripts": {
    "agents": "CI=true nx run --tui=false",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --typecheck --passWithNoTests",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@opentf/cli-pbar": "^0.7.2",
    "@viteval/core": "workspace:*",
    "@viteval/internal": "workspace:*",
    "@viteval/ui": "workspace:*",
    "c12": "^3.3.3",
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "find-up": "^8.0.0",
    "glob": "^13.0.6",
    "jiti": "2.6.1",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "ts-pattern": "^5.9.0",
    "type-fest": "^5.5.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
