{
  "name": "viteval",
  "version": "0.5.9",
  "description": "Next generation LLM evaluation framework powered by Vitest.",
  "keywords": [
    "ai",
    "evaluation",
    "javascript",
    "llm",
    "testing",
    "typescript",
    "vitest"
  ],
  "homepage": "https://github.com/viteval/viteval#readme",
  "bugs": "https://github.com/viteval/viteval/issues",
  "license": "MIT",
  "author": "viteval",
  "repository": "viteval/viteval",
  "bin": {
    "viteval": "./cli.mjs"
  },
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs"
    },
    "./dataset": {
      "types": "./dist/dataset.d.mts",
      "import": "./dist/dataset.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --typecheck --passWithNoTests",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@viteval/cli": "workspace:*",
    "@viteval/core": "workspace:*",
    "@viteval/internal": "workspace:*",
    "@viteval/ui": "workspace:*",
    "vitest": "^4.1.2"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  }
}
