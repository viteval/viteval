{
  "name": "@viteval/core",
  "version": "1.0.0-rc.0",
  "description": "Core - Next generation LLM evaluation framework powered by Vitest.",
  "homepage": "https://github.com/viteval/viteval#readme",
  "bugs": "https://github.com/viteval/viteval/issues",
  "repository": "viteval/viteval",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/main/index.mjs",
  "types": "dist/main/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/main/index.d.mts",
      "import": "./dist/main/index.mjs"
    },
    "./config": {
      "types": "./dist/config/index.d.mts",
      "import": "./dist/config/index.mjs"
    },
    "./dataset": {
      "types": "./dist/dataset/index.d.mts",
      "import": "./dist/dataset/index.mjs"
    },
    "./reporters": {
      "types": "./dist/reporters/index.d.mts",
      "import": "./dist/reporters/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --typecheck",
    "types": "tsc --noEmit --project tsconfig.build.json"
  },
  "dependencies": {
    "@vitest/runner": "^4.1.2",
    "@viteval/internal": "workspace:^",
    "ajv": "^8.18.0",
    "autoevals": "^0.0.132",
    "chalk": "^5.6.2",
    "compute-cosine-similarity": "^1.1.0",
    "find-up": "^8.0.0",
    "js-levenshtein": "^1.1.6",
    "js-yaml": "^4.1.1",
    "linear-sum-assignment": "^1.0.9",
    "mustache": "^4.2.0",
    "openai": "^6.33.0",
    "ts-pattern": "^5.9.0",
    "vite-node": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/js-levenshtein": "^1.1.3",
    "@types/js-yaml": "^4.0.9",
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "tsdown": "^0.21.7",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
