{
  "name": "@viteval/providers",
  "version": "0.5.9",
  "description": "Provider implementations for Viteval — SQLite (default), PostgreSQL, and third-party platforms.",
  "homepage": "https://github.com/viteval/viteval#readme",
  "bugs": "https://github.com/viteval/viteval/issues",
  "license": "MIT",
  "repository": "viteval/viteval",
  "files": [
    "dist",
    "prisma"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./viteval": {
      "types": "./dist/viteval.d.mts",
      "import": "./dist/viteval.mjs"
    },
    "./braintrust": {
      "types": "./dist/braintrust.d.mts",
      "import": "./dist/braintrust.mjs"
    }
  },
  "scripts": {
    "build": "prisma generate && tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --typecheck --passWithNoTests",
    "types": "prisma generate && tsc --noEmit",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@viteval/core": "workspace:^",
    "@viteval/internal": "workspace:^",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@braintrust/api": "^0.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "pg": "^8.16.2",
    "prisma": "^7.6.0",
    "tsdown": "^0.21.7",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@braintrust/api": ">=0.5.0",
    "@prisma/adapter-pg": ">=7.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@braintrust/api": {
      "optional": true
    },
    "@prisma/adapter-pg": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  }
}
