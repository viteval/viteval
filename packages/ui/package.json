{
  "name": "@viteval/ui",
  "version": "1.0.0-rc.0",
  "description": "Viteval UI - local UI for viewing the results of your evals",
  "homepage": "https://github.com/viteval/viteval#readme",
  "bugs": "https://github.com/viteval/viteval/issues",
  "license": "MIT",
  "repository": "viteval/viteval",
  "files": [
    "dist",
    "server.d.ts",
    "server.mjs",
    "server.mjs.map"
  ],
  "type": "module",
  "main": "dist/server.mjs",
  "module": "dist/server.mjs",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./server.d.ts",
      "import": "./server.mjs"
    }
  },
  "scripts": {
    "build:server": "tsdown",
    "build:ui": "next build && cp -r public dist/.next/standalone/packages/ui/public && cp -r dist/.next/static dist/.next/standalone/packages/ui/dist/.next/static",
    "dev": "next dev --port 6274",
    "start": "node dist/.next/standalone/packages/ui/server.js",
    "types": "next typegen && pnpm tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "find-up": "^8.0.0",
    "geist": "^1.7.0",
    "get-port": "^7.1.0",
    "hono": "^4.12.9",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.556.0",
    "next": "^16.2.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "ts-pattern": "^5.9.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.2.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  }
}
