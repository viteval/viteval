{
  "name": "viteval-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Next generation LLM evaluation framework powered by Vitest.",
  "scripts": {
    "build": "nx run-many -t build --parallel --projects=packages/*",
    "build:website": "nx run-many -t build --parallel --p website",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "check": "pnpm lint && pnpm format",
    "dev": "nx run-many -t dev --parallel --projects=packages/*",
    "dev:website": "nx dev website",
    "fix": "pnpm lint:fix && pnpm format:fix",
    "gen": "nx generate",
    "nuke": "nuka-code",
    "publish": "pnpm run build && pnpm changeset publish",
    "sp": "syncpack",
    "test": "nx run-many -t test --parallel --projects=packages/*",
    "types": "nx run-many -t types --parallel",
    "validate": "CI=true nx run-many -t check,types,test,build --parallel --projects=packages/*",
    "types:packages": "nx run-many -t types --parallel --projects=packages/*",
    "types:examples": "nx run-many -t types --parallel --projects=examples/*",
    "version": "pnpm changeset version && pnpm install --no-frozen-lockfile"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@nx/js": "22.6.3",
    "@nx/plugin": "22.6.3",
    "@nx/vite": "22.6.3",
    "@nx/web": "22.6.3",
    "@nx/workspace": "^22.6.3",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.21",
    "@swc/helpers": "~0.5.20",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "jiti": "2.6.1",
    "jsdom": "~29.0.1",
    "nuka-code": "^0.1.13",
    "nx": "22.6.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "syncpack": "^14.3.0",
    "tsdown": "^0.21.7",
    "tslib": "^2.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.14.0"
}
